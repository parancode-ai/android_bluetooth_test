<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_pill_background"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <ImageView
        android:id="@+id/widget_art"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/widget_art_background"
        android:scaleType="centerCrop"
        android:src="@mipmap/ic_launcher" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/app_name"
            android:textColor="#111111"
            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_shuffle"
        android:layout_width="42dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="⇄"
        android:textColor="#111111"
        android:textSize="25sp" />

    <TextView
        android:id="@+id/widget_previous"
        android:layout_width="42dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="⏮"
        android:textColor="#111111"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/widget_play"
        android:layout_width="52dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="▶"
        android:textColor="#111111"
        android:textSize="30sp" />

    <TextView
        android:id="@+id/widget_next"
        android:layout_width="42dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="⏭"
        android:textColor="#111111"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/widget_repeat"
        android:layout_width="42dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="A↔"
        android:textColor="#111111"
        android:textSize="21sp" />
</LinearLayout>
